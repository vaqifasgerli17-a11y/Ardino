const int trigPin = 13;
const int echoPin = 12;
const int ledUzaq=2;
const int ledYaxin=3;

long duration;
int distance;

void setup() {

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  pinMode(ledUzaq,OUTPUT);
  pinMode(ledYaxin,OUTPUT);
  

  Serial.begin(9600);
}

void loop() {
 
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  
  
  duration = pulseIn(echoPin, HIGH);
  
  distance = duration * 0.034 / 2;
  
  if(distance>10){
    digitalWrite(ledUzaq,LOW);
    digitalWrite(ledYaxin,HIGH);
  }

  Serial.print("Mesafe:");
  Serial.print(distance);
  Serial.println(" cm");
  
  // Qısa fasilə
  delay(500);
}



