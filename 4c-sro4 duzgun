const int trigPin = 11;
const int echoPin = 13;
const int ledUzaq = 10;
const int ledYaxin = 9;

long duration;
int distance;

void setup() {
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  pinMode(ledUzaq, OUTPUT);
  pinMode(ledYaxin, OUTPUT);
  Serial.begin(9600);
}

void loop() {
  // Ultrasonik siqnal göndər
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Əks-sədanı oxu və məsafəni hesabla
  duration = pulseIn(echoPin, HIGH);
  distance = duration * 0.034 / 2;

  // ✅ Düzəldilmiş məntiQ
  if (distance <= 10) {
    digitalWrite(ledYaxin, HIGH);  // Yaxında — sarı/qırmızı LED
    digitalWrite(ledUzaq, LOW);
  } else {
    digitalWrite(ledYaxin, LOW);
    digitalWrite(ledUzaq, HIGH);   // Uzaqda — yaşıl LED
  }

  Serial.print("Mesafe: ");
  Serial.print(distance);
  Serial.println(" cm");

  delay(500);
}
